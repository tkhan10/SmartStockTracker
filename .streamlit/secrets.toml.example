# Copy this to .streamlit/secrets.toml for local testing via st.secrets,
# or paste these same keys into the "Secrets" box in Streamlit Community Cloud's
# app settings (Settings -> Secrets) when deploying.

FINNHUB_API_KEY = "your_finnhub_api_key_here"
STOCK_DATA_PROVIDER = "yfinance"

# SMTP settings for sending price-alert emails (Phase 2).
SMTP_HOST = "smtp.example.com"
SMTP_PORT = "587"
SMTP_USERNAME = "you@example.com"
SMTP_PASSWORD = "your_smtp_password_or_app_password"
ALERT_FROM_EMAIL = "you@example.com"
