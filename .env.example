FINNHUB_API_KEY=your_finnhub_api_key_here

# Which data provider to use by default: "finnhub" or "yfinance"
# yfinance needs no API key. You can also switch providers live from the app's sidebar.
STOCK_DATA_PROVIDER=finnhub

# SMTP settings for sending price-alert emails (Phase 2). An app-password from
# Gmail/Outlook/etc. works well for SMTP_PASSWORD.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=your_smtp_password_or_app_password
ALERT_FROM_EMAIL=tofek.khan87@gmail.com
